<%- include('partials/header',{title:'Tổng quan'}) %><div class="page-head"><div><h1>Xin chào, <%= currentUser.name %></h1><p><span class="badge"><%= currentUser.role %></span> <%= currentUser.groupName ? '• '+currentUser.groupName : '' %></p></div><a class="button primary" href="/map">Mở bản đồ</a></div><section class="stats"><article><b><%= stats.waypointCount %></b><span>Waypoint được phép xem</span></article><article><b><%= stats.trackCount %></b><span>Tracklog được phép xem</span></article><article><b><%= stats.userCount %></b><span>Người dùng/phạm vi nhóm</span></article><% if(currentUser.role==='admin'){ %><article><b><%= stats.pendingCount %></b><span>Đăng ký chờ duyệt</span></article><% } %></section><section class="panel"><h2>Phạm vi dữ liệu</h2><p><% if(currentUser.role==='admin'){ %>Admin có thể xem và quản lý toàn bộ dữ liệu, nhóm và người dùng.<% } else if(currentUser.role==='mod'){ %>Mod chỉ xem dữ liệu của nhóm mình và chỉnh sửa thông tin thành viên trong nhóm.<% } else { %>Thành viên chỉ xem và quản lý waypoint, tracklog do chính mình tạo.<% } %></p></section><%- include('partials/footer') %>

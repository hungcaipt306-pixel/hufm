<%- include('partials/header',{title:'Thành viên nhóm'}) %><div class="page-head"><div><h1>Thành viên nhóm</h1><p>Mod chỉ chỉnh sửa thông tin thành viên thuộc nhóm mình.</p></div></div><section class="cards"><% users.forEach(u=>{ %><article class="panel"><form method="post" action="/group/members/<%=u.id%>/update"><label>Họ tên<input name="name" value="<%=u.name%>"></label><label>Email<input value="<%=u.email%>" disabled></label><label>Điện thoại<input name="phone" value="<%=u.phone||''%>"></label><label>Đơn vị<input name="unit" value="<%=u.unit||''%>"></label><p><span class="badge"><%=u.role%></span></p><button>Lưu thông tin</button></form></article><% }) %></section><%- include('partials/footer') %>

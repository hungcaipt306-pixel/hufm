<!doctype html>
<html lang="vi">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
  <meta name="theme-color" content="#0d4b34">
  <meta name="application-name" content="HUFM - Hue Forest Manager">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="HUFM - Hue Forest Manager">
  <title><%= title ? title + ' | HUFM' : 'HUFM - Hue Forest Manager' %></title>
  <link rel="icon" type="image/png" href="/favicon.png">
  <link rel="manifest" href="/manifest.webmanifest">
  <link rel="apple-touch-icon" href="/favicon.png">
  <link rel="stylesheet" href="/style.css">
  <% if (typeof mapPage !== 'undefined' && mapPage) { %>
    <link rel="stylesheet" href="/vendor/leaflet/leaflet.css">
  <% } %>
</head>
<body class="<%= typeof mapPage !== 'undefined' && mapPage ? 'map-page ifmc-shell' : 'ifmc-shell' %>">
<header class="topbar">
  <div class="topbar-inner">
    <a class="brand" href="<%= currentUser ? '/map' : '/' %>">
      <img class="brand-logo" src="/logo-kiem-lam-hue.png" alt="Logo Kiểm lâm Huế">
      <span><strong>HUFM</strong><small>Hue Forest Manager</small></span>
    </a>
    <% if(currentUser){ %>
      <div class="header-summary" aria-label="Thông tin tài khoản">
        <span class="summary-name"><%= currentUser.name %></span>
        <span class="summary-role"><%= currentUser.role %><%= currentUser.groupName ? ' • '+currentUser.groupName : '' %></span>
      </div>
      <button class="menu-toggle" id="menuToggle" type="button" aria-label="Mở menu" aria-expanded="false" aria-controls="mainNav"><span></span><span></span><span></span></button>
      <nav id="mainNav" class="main-nav">
        <a href="/dashboard">⌂ Tổng quan</a>
        <a href="/map">🗺 Bản đồ</a><a href="/operations">🛡 Nghiệp vụ</a>
        <% if(currentUser.role==='admin'){ %><a href="/admin/users">👥 Tài khoản</a><a href="/admin/groups">▦ Nhóm</a><% } %>
        <% if(currentUser.role==='mod'){ %><a href="/group/members">👥 Thành viên</a><% } %>
        <form method="post" action="/logout"><button class="link-btn">↪ Đăng xuất</button></form>
      </nav>
    <% } else { %>
      <nav class="guest-nav"><a href="/login">Đăng nhập</a><a class="guest-register" href="/register">Đăng ký</a></nav>
    <% } %>
  </div>
</header>
<main class="container"><% if(flash){ %><div class="flash <%= flash.type %>"><%= flash.message %></div><% } %>

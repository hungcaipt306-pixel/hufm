<!doctype html><html lang="vi"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1">
<title><%= title || 'Quản lý rừng Huế' %></title><link rel="stylesheet" href="/style.css">
<% if (typeof mapPage !== 'undefined' && mapPage) { %><link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"><% } %>
</head><body>
<header class="topbar"><a class="brand" href="/dashboard">🌲 Kiểm lâm Huế</a><% if(currentUser){ %><nav><a href="/dashboard">Tổng quan</a><a href="/map">Bản đồ</a><% if(currentUser.role==='admin'){ %><a href="/admin/users">Người dùng</a><a href="/admin/groups">Nhóm</a><% } %><% if(currentUser.role==='mod'){ %><a href="/group/members">Thành viên nhóm</a><% } %><form method="post" action="/logout"><button class="link-btn">Đăng xuất</button></form></nav><% } %></header>
<main class="container"><% if(flash){ %><div class="flash <%= flash.type %>"><%= flash.message %></div><% } %>

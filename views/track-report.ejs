<!doctype html><html lang="vi"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width"><title>Báo cáo <%= track.name %></title><style>body{font-family:Arial,sans-serif;max-width:900px;margin:30px auto;color:#17382d}h1{color:#07583d}table{width:100%;border-collapse:collapse}th,td{border:1px solid #ccc;padding:8px;text-align:left}.actions{margin:20px 0}@media print{.actions{display:none}}</style></head><body><div class="actions"><button onclick="window.print()">In / Lưu PDF</button><a href="/map">Quay lại bản đồ</a></div><h1>Phiếu tuần tra rừng</h1><p><b>Tuyến:</b> <%= track.name %></p><p><b>Cán bộ:</b> <%= track.User?.name||'' %> • <b>Đơn vị:</b> <%= track.User?.unit||'' %> • <b>Nhóm:</b> <%= track.Group?.name||'' %></p><p><b>Thời gian:</b> <%= new Date(track.startedAt||track.createdAt).toLocaleString('vi-VN') %> – <%= new Date(track.endedAt||track.updatedAt).toLocaleString('vi-VN') %></p><p><b>Quãng đường:</b> <%= ((track.distanceMeters||0)/1000).toFixed(2) %> km • <b>Số điểm GPS:</b> <%= track.points.length %></p><p><b>Mô tả:</b> <%= track.description||'' %></p><h2>Waypoint đối chiếu</h2><table><thead><tr><th>Tên</th><th>Phân loại</th><th>Tọa độ</th><th>Thời gian</th></tr></thead><tbody><% waypoints.forEach(w=>{ %><tr><td><%= w.name %></td><td><%= w.category %></td><td><%= w.latitude.toFixed(6) %>, <%= w.longitude.toFixed(6) %></td><td><%= new Date(w.createdAt).toLocaleString('vi-VN') %></td></tr><% }) %></tbody></table></body></html>

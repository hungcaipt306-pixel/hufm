<%- include('partials/header',{title:'Bản đồ số',mapPage:true}) %><div class="page-head"><div><h1>Bản đồ quản lý rừng</h1><p>OpenStreetMap • định vị nhanh • waypoint • tracklog</p></div><a class="button" href="/api/export/geojson">Tải GeoJSON</a></div>
<div class="map-layout"><aside class="map-tools"><button id="locateBtn" class="primary">📍 Định vị nhanh</button><button id="addWpBtn">➕ Lưu waypoint tại vị trí hiện tại</button><button id="startTrackBtn">▶ Bắt đầu ghi tracklog</button><button id="stopTrackBtn" disabled>⏹ Dừng và lưu tracklog</button><div id="status" class="status">Sẵn sàng.</div><hr><h3>Dữ liệu hiển thị</h3><div id="dataList" class="data-list"></div></aside><div id="map"></div></div>
<div id="modal" class="modal hidden"><div class="modal-box"><h3 id="modalTitle">Lưu dữ liệu</h3><label>Tên<input id="itemName"></label><label>Mô tả<textarea id="itemDescription"></textarea></label><label id="categoryWrap">Phân loại<select id="itemCategory"><option>Chốt bảo vệ rừng</option><option>Khu vực nguy cơ</option><option>Dấu vết vi phạm</option><option>Điểm tuần tra</option><option>Khác</option></select></label><div class="actions"><button id="cancelModal">Hủy</button><button id="saveModal" class="primary">Lưu</button></div></div></div>
<script>window.APP_USER=<%- JSON.stringify(currentUser) %>;</script><script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script><script src="/map.js"></script><%- include('partials/footer') %>

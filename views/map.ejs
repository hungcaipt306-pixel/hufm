<%- include('partials/header',{title:'Bản đồ số',mapPage:true}) %>
<div class="page-head map-head"><div><h1>Bản đồ quản lý rừng</h1><p>Giám sát hiện trường • dữ liệu nhóm • làm việc offline</p></div><div class="map-head-actions"><button id="panelToggle" class="button compact-button" type="button">☰ Công cụ</button><a class="button compact-button" href="/api/export/geojson">⇩ GeoJSON</a></div></div>
<div class="map-layout">
  <aside class="map-tools ifmc-drawer" id="mapTools" aria-label="Bảng điều khiển bản đồ"><div class="drawer-title"><span><b>HUFM</b><small>Forest Management</small></span><button id="panelClose" type="button" aria-label="Đóng bảng công cụ">×</button></div>
    <div class="mobile-tool-handle" aria-hidden="true"></div>
    <div class="drawer-scroll" id="drawerScroll">
    <div id="status" class="status" role="status" aria-live="polite">Sẵn sàng.</div>
    <div class="network-bar"><span id="networkDot"></span><b id="networkText">Đang kiểm tra mạng</b><span id="pendingCount">0 bản ghi chờ</span></div>
    <details class="data-panel offline-panel" open>
      <summary>🗺️ Bản đồ và dữ liệu offline</summary>
      <div class="offline-controls">
        <label>Mức zoom tải về<select id="offlineZoom"><option value="12-14">12–14 (khu vực rộng)</option><option value="13-15" selected>13–15 (khuyến nghị)</option><option value="14-16">14–16 (chi tiết)</option></select></label>
        <button id="downloadOfflineBtn" type="button" class="primary">Tải vùng đang xem</button>
        <button id="syncNowBtn" type="button">Đồng bộ ngay</button>
        <button id="clearOfflineBtn" type="button" class="danger">Xóa bản đồ offline</button>
        <div id="offlineStatus" class="source-note">Vùng tải được tính theo khung bản đồ hiện tại.</div>
      </div>
    </details>
    <details class="data-panel" open><summary>Dữ liệu hiển thị</summary><div id="dataList" class="data-list"></div></details>
    <details class="data-panel fire-panel" open>
      <summary>🔥 Thời tiết & nguy cơ cháy rừng</summary>
      <div class="weather-location-row"><span id="weatherLocation">Trung tâm thành phố Huế</span><button id="weatherHereBtn" type="button">Theo vị trí GPS</button></div>
      <div id="weatherRiskHero" class="weather-risk-hero"><b>Đang tải dự báo…</b></div>
      <div id="weatherNow" class="weather-now"></div>
      <div id="weatherForecast" class="weather-forecast"></div>
      <div id="weatherAdvice" class="weather-advice"></div>
      <button id="refreshWeatherBtn" type="button" class="primary full-button">Làm mới thời tiết & nguy cơ</button>
      <small id="weatherDisclaimer" class="weather-disclaimer">Chỉ số hỗ trợ nghiệp vụ, không thay thế cấp dự báo chính thức.</small>
      <hr class="panel-divider">
      <h4 class="subpanel-title">Điểm cảnh báo/điểm nóng</h4>
      <div class="fire-controls">
        <label>Địa bàn phường/xã<select id="fireWard"><option value="">Toàn thành phố Huế</option></select></label>
        <div class="fire-actions"><button id="refreshFireBtn" type="button" class="primary">Làm mới cảnh báo</button><a id="openPcccrBtn" class="button" href="https://v2.pcccr.vn/diem-chay" target="_blank" rel="noopener noreferrer">Mở bản đồ PCCCR</a></div>
      </div>
      <div id="fireStatus" class="source-note">Đang kiểm tra nguồn cảnh báo…</div>
      <div id="specialUnitsNote" class="source-note administrative-note">Đơn vị biển đảo: Đặc khu Hoàng Sa • Đặc khu Trường Sa</div>
      <div class="fire-legend"><span class="fire-dot"></span> Điểm nghi ngờ/cháy từ nguồn PCCCR đã cấu hình</div>
    </details>
    <details class="data-panel layer-panel" open>
      <summary>Lớp bản đồ tải lên</summary>
      <form id="layerUploadForm" class="layer-upload-form" enctype="multipart/form-data">
        <label>Tên lớp<input id="layerName" name="name" placeholder="Tự lấy theo tên tệp"></label>
        <label>Tệp bản đồ<input id="layerFile" name="file" type="file" accept=".geojson,.json,.kml,.mbtiles" required></label>
        <label>Mô tả<textarea id="layerDescription" name="description" placeholder="Thông tin lớp bản đồ"></textarea></label>
        <button class="primary" type="submit">⬆ Tải lớp lên</button>
        <small>Hỗ trợ GeoJSON, KML và MBTiles. Giới hạn mặc định 50 MB.</small>
      </form>
      <div id="layerList" class="data-list layer-list"></div>
    </details>
    </div>
  </aside>
  <div class="map-stage">
    <div id="map" aria-label="Bản đồ quản lý rừng"></div>
    <div class="map-primary-actions" aria-label="Công cụ hiện trường">
      <button id="locateBtn" class="primary active-tool" type="button" title="Định vị và bám theo vị trí">⌖ <span>Định vị</span></button>
      <button id="headingUpBtn" type="button" title="Xoay bản đồ theo hướng điện thoại" aria-pressed="false">➤ <span>Hướng lên</span></button>
      <button id="addWpBtn" type="button" title="Lưu waypoint tại vị trí hiện tại">＋ <span>Waypoint</span></button>
      <button id="startTrackBtn" type="button" title="Bắt đầu ghi tracklog">▶ <span>Ghi tuyến</span></button>
      <button id="stopTrackBtn" type="button" title="Dừng và lưu tracklog" disabled>■ <span>Dừng</span></button>
    </div>
    <div class="map-corner-actions" aria-label="Tải và cập nhật">
      <button id="vietnamOverviewBtn" type="button" title="Xem toàn cảnh Việt Nam, Hoàng Sa và Trường Sa">🇻🇳 <span>Việt Nam</span></button>
      <button id="reloadLayersBtn" type="button" title="Tải lại các lớp bản đồ">▧ <span>Lớp bản đồ</span></button>
      <button id="updateAppBtn" class="sync-refresh-button" type="button" title="Cập nhật dữ liệu và phiên bản ứng dụng">🔄 <span>Cập nhật</span></button>
    </div>
    <div id="mapLoading" class="map-loading" aria-live="polite"><span></span><b>Đang tải bản đồ…</b></div>
    <div id="appToast" class="app-toast" role="status" aria-live="polite"></div>
    <div class="live-location-card" id="liveLocationCard" aria-live="polite">
      <b id="liveLocationState">GPS chưa bật</b>
      <span id="liveLocationDetail">Bấm Định vị để theo dõi realtime</span>
    </div>
  </div>
</div>
<div id="modal" class="modal hidden" role="dialog" aria-modal="true" aria-labelledby="modalTitle"><div class="modal-box"><h3 id="modalTitle">Lưu dữ liệu</h3><label>Tên<input id="itemName"></label><label>Mô tả<textarea id="itemDescription"></textarea></label><label id="categoryWrap">Phân loại<select id="itemCategory"><option>Chốt bảo vệ rừng</option><option>Khu vực nguy cơ</option><option>Dấu vết vi phạm</option><option>Điểm tuần tra</option><option>Khác</option></select></label><div class="actions"><button id="cancelModal">Hủy</button><button id="saveModal" class="primary">Lưu</button></div></div></div>
<script>window.APP_USER=<%- JSON.stringify(currentUser) %>;</script><script src="/vendor/leaflet/leaflet.js"></script><script src="/vendor/vectorgrid/Leaflet.VectorGrid.bundled.js"></script><script src="/offline-db.js"></script><script src="/map.js"></script><%- include('partials/footer') %>

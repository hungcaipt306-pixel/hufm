<%- include('partials/header',{title:'Trung tâm nghiệp vụ'}) %>
<div class="page-head"><div><h1>Trung tâm nghiệp vụ</h1><p>Phân công tuần tra • SOS • trực ban • nhật ký thay đổi</p></div><a class="button primary" href="/map">Mở bản đồ</a></div>
<section class="ops-grid">
  <article class="panel"><h2>Phân công tuần tra</h2>
  <% if(['admin','mod'].includes(currentUser.role)){ %><form method="post" action="/operations/assignments" class="stack-form"><label>Tên nhiệm vụ<input name="title" required></label><label>Mô tả<textarea name="description"></textarea></label><div class="form-grid"><label>Bắc<input name="north" value="16.7" type="number" step="any"></label><label>Nam<input name="south" value="16.2" type="number" step="any"></label><label>Đông<input name="east" value="107.9" type="number" step="any"></label><label>Tây<input name="west" value="107.2" type="number" step="any"></label></div><div class="form-grid"><label>Nhóm<select name="groupId"><option value="">Không chọn</option><% groups.forEach(g=>{ %><option value="<%= g.id %>"><%= g.name %></option><% }) %></select></label><label>Người nhận<select name="assigneeId"><option value="">Cả nhóm</option><% users.forEach(u=>{ %><option value="<%= u.id %>"><%= u.name %></option><% }) %></select></label><label>Ngưỡng cảnh báo<select name="riskThreshold"><option value="3">Cấp III</option><option value="4" selected>Cấp IV</option><option value="5">Cấp V</option></select></label><label>Hạn hoàn thành<input name="dueAt" type="datetime-local"></label></div><button class="primary">Giao nhiệm vụ</button></form><% } %>
  <div class="ops-list"><% assignments.forEach(a=>{ %><div class="ops-card"><b><%= a.title %></b><small><%= a.Group?.name||'Chưa gán nhóm' %> • <%= a.Assignee?.name||'Cả nhóm' %></small><p><%= a.description||'' %></p><form method="post" action="/operations/assignments/<%= a.id %>/status"><select name="status"><option value="assigned" <%= a.status==='assigned'?'selected':'' %>>Đã giao</option><option value="in_progress" <%= a.status==='in_progress'?'selected':'' %>>Đang thực hiện</option><option value="completed" <%= a.status==='completed'?'selected':'' %>>Hoàn thành</option><option value="cancelled" <%= a.status==='cancelled'?'selected':'' %>>Hủy</option></select><button>Cập nhật</button></form></div><% }) %></div>
  </article>
  <article class="panel"><h2>Cảnh báo SOS</h2><div class="ops-list"><% alerts.forEach(a=>{ %><div class="ops-card sos-<%= a.status %>"><b><%= a.User?.name||'Cán bộ' %></b><small><%= new Date(a.createdAt).toLocaleString('vi-VN') %> • ±<%= Math.round(a.accuracy||0) %>m</small><p><%= a.message||'Yêu cầu hỗ trợ khẩn cấp' %></p><a target="_blank" rel="noopener" href="https://www.openstreetmap.org/?mlat=<%= a.latitude %>&mlon=<%= a.longitude %>#map=17/<%= a.latitude %>/<%= a.longitude %>">Mở vị trí</a><% if(['admin','mod'].includes(currentUser.role)){ %><form method="post" action="/operations/sos/<%= a.id %>/status"><select name="status"><option value="open" <%= a.status==='open'?'selected':'' %>>Mới</option><option value="acknowledged" <%= a.status==='acknowledged'?'selected':'' %>>Đã tiếp nhận</option><option value="resolved" <%= a.status==='resolved'?'selected':'' %>>Đã xử lý</option></select><button>Cập nhật</button></form><% } %></div><% }) %></div></article>
  <article class="panel"><h2>Bảng trực ban</h2><div class="ops-list"><% if(!presence.length){ %><p>Chưa có cán bộ hoạt động trong 5 phút gần đây.</p><% } %><% presence.forEach(p=>{ %><div class="ops-card"><b><%= p.user.name %></b><small><%= p.tracking?'Đang ghi tuyến':'Đang online' %> • cập nhật <%= new Date(p.updatedAt).toLocaleTimeString('vi-VN') %></small><% if(p.latitude&&p.longitude){ %><a target="_blank" rel="noopener" href="https://www.openstreetmap.org/?mlat=<%= p.latitude %>&mlon=<%= p.longitude %>#map=16/<%= p.latitude %>/<%= p.longitude %>">Xem vị trí gần nhất</a><% } %></div><% }) %></div></article>
  <article class="panel"><h2>Nhật ký thay đổi</h2><div class="audit-list"><% logs.forEach(l=>{ %><div><b><%= l.User?.name||'Hệ thống' %></b> <%= l.action %> <%= l.entityType %> #<%= l.entityId %><small><%= new Date(l.createdAt).toLocaleString('vi-VN') %></small></div><% }) %></div></article>
  <article class="panel"><h2>Chức năng đã tích hợp</h2><ul class="feature-list"><li>Bản đồ nguy cơ cháy và cảnh báo theo khu vực phụ trách.</li><li>Nhật ký tuần tra có waypoint, ảnh hiện trường và báo cáo in/PDF.</li><li>So sánh hai tracklog trên bản đồ.</li><li>SOS gửi vị trí tức thời cho quản trị và nhóm.</li><li>Phân công nhiệm vụ theo vùng bản đồ.</li><li>Bảng trực ban, chất lượng GPS và lịch sử chỉnh sửa.</li></ul></article>
</section>
<%- include('partials/footer') %>

<%- include('partials/header',{title:'Quản lý nhóm'}) %><div class="page-head"><div><h1>Quản lý nhóm</h1><p>Tạo nhóm và xem danh sách thành viên.</p></div></div><section class="panel"><h2>Tạo nhóm mới</h2><form method="post" action="/admin/groups" class="row-form"><input name="name" placeholder="Tên nhóm" required><input name="description" placeholder="Mô tả"><button class="primary">Tạo nhóm</button></form></section><section class="cards"><% groups.forEach(g=>{ %><article class="panel"><form method="post" action="/admin/groups/<%=g.id%>/update"><input name="name" value="<%=g.name%>" required><textarea name="description"><%=g.description||''%></textarea><button>Lưu thay đổi</button></form><p><b><%=g.Users.length%></b> thành viên</p><ul><% g.Users.forEach(u=>{ %><li><%=u.name%> — <%=u.role%></li><% }) %></ul><form method="post" action="/admin/groups/<%=g.id%>/delete"><button class="danger">Xóa nhóm</button></form></article><% }) %></section><%- include('partials/footer') %>

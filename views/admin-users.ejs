<%- include('partials/header',{title:'Quản lý người dùng'}) %><div class="page-head"><div><h1>Quản lý người dùng</h1><p>Duyệt đăng ký, phân vai trò và gán nhóm.</p></div></div><section class="table-wrap"><table><thead><tr><th>Thành viên</th><th>Trạng thái</th><th>Vai trò/nhóm</th><th>Thông tin</th><th>Thao tác</th></tr></thead><tbody><% users.forEach(u=>{ %><tr><td><b><%= u.name %></b><br><small><%= u.email %></small></td><td><span class="badge <%= u.status %>"><%= u.status %></span></td><td><form method="post" action="/admin/users/<%= u.id %>/update" class="inline-form"><select name="role"><option value="user" <%=u.role==='user'?'selected':''%>>user</option><option value="mod" <%=u.role==='mod'?'selected':''%>>mod</option><option value="admin" <%=u.role==='admin'?'selected':''%>>admin</option></select><select name="groupId"><option value="">Không thuộc nhóm</option><% groups.forEach(g=>{ %><option value="<%=g.id%>" <%=u.groupId===g.id?'selected':''%>><%=g.name%></option><% }) %></select></td><td><input name="name" value="<%=u.name%>"><input name="phone" value="<%=u.phone||''%>" placeholder="Điện thoại"><input name="unit" value="<%=u.unit||''%>" placeholder="Đơn vị"></td><td><button>Lưu</button></form><% if(u.status==='pending'){ %><form method="post" action="/admin/users/<%=u.id%>/approve"><button class="success">Duyệt</button></form><form method="post" action="/admin/users/<%=u.id%>/reject"><button class="danger">Từ chối</button></form><% } %></td></tr><% }) %></tbody></table></section><%- include('partials/footer') %>
